# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Environment
.env
.venv/
venv/

# Data (runtime artifacts)
data/videos/
data/assets/
data/models/
data/voices/
data/*.db
data/*.db-shm
data/*.db-wal

# Music: ignore audio files (large, licensed separately per-machine) but TRACK
# the per-category tracks.yaml manifests so curation + attribution stay in git.
data/music/**/*.mp3
data/music/**/*.wav
data/music/**/*.flac
data/music/**/*.m4a
data/music/**/*.ogg

# Character refs: ignore the generated candidates pool, track the locked hero image(s)
data/character_refs/candidates/

# Political-juxtaposition test item: downloaded source videos + extracted clip candidates
data/moments/

# Generated scripts for review/edit before commit to TTS+visuals stages
data/scripts/

# Pipeline run logs (verbose ffmpeg + API debug; can contain account-specific
# error messages). Keep them local for debugging, don't commit.
logs/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db
